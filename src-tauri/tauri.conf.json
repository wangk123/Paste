{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Paste",
  "version": "0.1.0",
  "identifier": "com.wangk.clipboard-history",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Paste",
        "width": 1200,
        "height": 500,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "center": false,
        "focus": true
      },
      {
        "label": "settings",
        "title": "Paste 设置",
        "url": "index.html",
        "width": 480,
        "height": 560,
        "minWidth": 400,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "skipTaskbar": false,
        "alwaysOnTop": true,
        "center": false,
        "focus": true
      },
      {
        "label": "preview",
        "title": "图片预览",
        "url": "index.html",
        "width": 800,
        "height": 600,
        "minWidth": 160,
        "minHeight": 120,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "skipTaskbar": false,
        "alwaysOnTop": true,
        "center": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "hardenedRuntime": true
    },
    "resources": {
      "resources/": ""
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
